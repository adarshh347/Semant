# API Configuration
# For local development, you can leave this commented out to use the default localhost:5007
# For production deployment on Vercel, set this to your backend URL
VITE_API_URL=https://sharirasutra.onrender.com

# Optional API key. Must match the backend's API_KEY env var when the backend
# has auth enabled. Leave unset for local dev against a keyless backend.
VITE_API_KEY=
