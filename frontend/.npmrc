# BlockNote (0.51.x) and TipTap (3.27.x) declare mismatched @tiptap/core peers
# (extension-floating-menu wants 3.27.4; @blocknote/core resolves 3.27.2). The
# tree works, but strict peer resolution rejects it — so `npm ci` fails in CI.
# legacy-peer-deps makes local installs and CI use the same tolerant resolution.
legacy-peer-deps=true
